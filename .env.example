# ============================================================================
# Covant — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ── Convex (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=             # Convex deployment URL (e.g. https://your-deployment.convex.cloud)

# ── Clerk Authentication (required) ───────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # Clerk publishable key
CLERK_SECRET_KEY=                   # Clerk secret key

# ── Stripe Payments (required for billing & payouts) ──────────────────────
STRIPE_SECRET_KEY=                  # Stripe secret API key
STRIPE_WEBHOOK_SECRET=              # Stripe webhook signing secret
STRIPE_PRICE_PRO_MONTHLY=           # Stripe Price ID for Pro monthly plan
STRIPE_PRICE_PRO_ANNUAL=            # Stripe Price ID for Pro annual plan
STRIPE_PRICE_SCALE_MONTHLY=         # Stripe Price ID for Scale monthly plan
STRIPE_PRICE_SCALE_ANNUAL=          # Stripe Price ID for Scale annual plan

# ── AI / LLM (optional — enables Ask Covant Q&A) ─────────────────────────
GROQ_API_KEY=                       # Groq API key for Llama 3.3 70B
# ANTHROPIC_API_KEY is auto-detected by the Anthropic SDK (for rule parsing)

# ── Email via Resend (optional — enables notifications) ───────────────────
RESEND_API_KEY=                     # Resend API key
RESEND_DOMAIN_VERIFIED=false        # Set to "true" once your domain is verified in Resend

# ── Salesforce CRM Integration (optional) ─────────────────────────────────
SALESFORCE_CLIENT_ID=               # Salesforce Connected App client ID
SALESFORCE_CLIENT_SECRET=           # Salesforce Connected App client secret
SALESFORCE_REDIRECT_URI=https://covant.ai/api/integrations/salesforce/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# ── HubSpot CRM Integration (optional) ───────────────────────────────────
HUBSPOT_CLIENT_ID=                  # HubSpot app client ID
HUBSPOT_CLIENT_SECRET=              # HubSpot app client secret
HUBSPOT_REDIRECT_URI=https://covant.ai/api/integrations/hubspot/callback

# ── Application Settings ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://covant.ai  # Base URL for links in emails and webhooks
ADMIN_SECRET=                          # Secret for /admin routes
COVANT_DEMO_MODE=false                 # Set to "true" to allow unauthenticated demo access
